# Required environment variables for the Wikly API server.
# Copy this file to .env and fill in the values from your Supabase project.

# Supabase project URL — found in: Supabase Dashboard > Project Settings > API > Project URL
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase service role key — found in: Supabase Dashboard > Project Settings > API > service_role (secret)
# Keep this secret — it bypasses Row Level Security.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Port the server listens on
PORT=3001

# Frontend origin for CORS (your GitHub Pages URL or localhost during development)
FRONTEND_ORIGIN=http://localhost:5173
